{
  "name": "c25-monorepo",
  "version": "2.1.0",
  "private": true,
  "workspaces": [
    "packages/backend",
    "packages/frontend",
    "packages/agents",
    "packages/orchestration"
  ],
  "scripts": {
    "build": "npm run build --workspaces --if-present",
    "start": "node packages/backend/index.js",
    "dev": "npm run dev --workspaces --if-present",
    "test": "npm run test --workspaces --if-present",
    "deploy": "git add -A && git commit -m 'monorepo update' && git push origin main && npx vercel --prod --force --yes"
  },
  "engines": { "node": ">=18" }
}
