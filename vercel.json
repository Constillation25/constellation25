{
  "version": 2,
  "buildCommand": "npm run build",
  "outputDirectory": ".",
  "installCommand": "npm install",
  "builds": [
    { "src": "packages/backend/index.js", "use": "@vercel/node" }
  ],
  "routes": [
    { "src": "/api/(.*)", "dest": "packages/backend/index.js" },
    { "src": "/health", "dest": "packages/backend/index.js" },
    { "src": "/webhook", "dest": "packages/backend/index.js" },
    { "src": "/(.*)", "dest": "packages/backend/index.js" }
  ]
}
